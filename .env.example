# ── Required ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # get from console.anthropic.com

# ── Ports ─────────────────────────────────────────────────────────────────────
AGENT_PORT=8000
DASHBOARD_PORT=3000

# ── Directories (relative to repo root) ───────────────────────────────────────
APPS_DIR=./apps
EVIDENCE_DIR=./evidence
RESULTS_DIR=./results
